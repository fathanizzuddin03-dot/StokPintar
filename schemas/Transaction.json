{
  "name": "Transaction",
  "type": "object",
  "properties": {
    "invoice_no": {
      "type": "string"
    },
    "channel": {
      "type": "string",
      "enum": [
        "offline",
        "whatsapp",
        "shopee",
        "tokopedia",
        "lazada",
        "tiktok",
        "grosir"
      ]
    },
    "items": {
      "type": "string",
      "description": "JSON array of items"
    },
    "subtotal": {
      "type": "number"
    },
    "shipping_cost": {
      "type": "number",
      "default": 0
    },
    "discount": {
      "type": "number",
      "default": 0
    },
    "total": {
      "type": "number"
    },
    "hpp_total": {
      "type": "number",
      "description": "Total HPP"
    },
    "profit": {
      "type": "number"
    },
    "payment_method": {
      "type": "string",
      "enum": [
        "cash",
        "transfer",
        "marketplace"
      ]
    },
    "customer_name": {
      "type": "string"
    },
    "customer_phone": {
      "type": "string"
    },
    "customer_address": {
      "type": "string"
    },
    "tracking_no": {
      "type": "string"
    },
    "expedition": {
      "type": "string"
    },
    "staff_id": {
      "type": "string"
    },
    "staff_name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "processing",
        "shipped",
        "completed",
        "voided",
        "returned"
      ],
      "default": "completed"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "channel",
    "items",
    "total"
  ]
}